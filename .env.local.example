# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Service Role Key (REQUIRED for public portfolio pages — bypasses RLS server-side)
# NEVER expose to the client. Get from Supabase > Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Impact Engine - GitHub Token Encryption
# Generate a secure 32-byte hex key: openssl rand -hex 32
GITHUB_TOKEN_ENCRYPTION_KEY=your-64-character-hex-key-here

# Narrative Storyboarder - OpenAI API
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# AI Technical Journey Generator - Anthropic Claude API
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
